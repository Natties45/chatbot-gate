FROM node:22-slim AS base

RUN apt-get update && apt-get install -y \
  chromium \
  chromium-sandbox \
  libxshmfence-dev \
  libnss3 \
  libnspr4 \
  libatk-bridge2.0-0 \
  libdrm2 \
  libcups2 \
  libxkbcommon0 \
  libxcomposite1 \
  libxdamage1 \
  libxrandr2 \
  libgbm1 \
  libpango-1.0-0 \
  --no-install-recommends \
  && rm -rf /var/lib/apt/lists/*

ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE=/usr/bin/chromium

WORKDIR /app

RUN npm install @playwright/mcp

EXPOSE 8931

CMD ["npx", "@playwright/mcp", "--port", "8931"]
