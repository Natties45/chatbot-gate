FROM ubuntu:24.04 AS base

RUN apt-get update && apt-get install -y curl ca-certificates nodejs npm --no-install-recommends && rm -rf /var/lib/apt/lists/*

ARG TARGETPLATFORM
RUN if [ "$TARGETPLATFORM" = "linux/arm64" ]; then \
      URL="https://github.com/anomalyco/opencode/releases/download/v1.17.9/opencode-linux-arm64.tar.gz"; \
    else \
      URL="https://github.com/anomalyco/opencode/releases/download/v1.17.9/opencode-linux-x64.tar.gz"; \
    fi && \
    curl -fsSL "$URL" | tar xzf - -C /usr/local/bin/

WORKDIR /chatbot-gate

RUN mkdir -p /root/.config/opencode && \
    echo '{"dependencies":{"@opencode-ai/plugin":"1.17.9","@ai-sdk/openai-compatible":"latest"}}' > /root/.config/opencode/package.json && \
    npm install --prefix /root/.config/opencode

EXPOSE 4096
CMD ["opencode", "serve", "--hostname", "0.0.0.0", "--port", "4096"]
