{
  "name": "chatbot-gate-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web1",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web1",
    "build:web": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web1"
  }
}
