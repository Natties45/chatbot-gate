{
  "name": "chatbot-gate-monorepo",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/app2",
    "dev:docker": "docker compose -f docker-compose.dev.yml up -d",
    "build": "npm run build --workspace=apps/app2",
    "start": "npm run start --workspace=apps/app2",
    "lint": "npm run lint --workspace=apps/app2",
    "clean": "rm -rf apps/app2/.next node_modules"
  }
}
